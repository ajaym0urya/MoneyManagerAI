# Google Cloud Vertex AI / Gemini config
# To use Gemini API directly if not using Vertex AI, use GEMINI_API_KEY. Defaulting to standard API for portability.
GEMINI_API_KEY="your_gemini_api_key_here"

# GCP Project Info (For Vertex AI / Firestore)
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"

# Firebase Config (Optional, usually handled automatically in Cloud Run)
FIREBASE_CREDENTIALS_PATH="./firebase-adminsdk.json"

# App Config
PORT=8000
